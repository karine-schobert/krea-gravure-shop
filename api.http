@baseUrl = http://127.0.0.1:8000
@json = application/json

### =========================================================
### 0) SANITY CHECK
### =========================================================

### HEALTH
GET {{baseUrl}}/api/health
Accept: {{json}}

### =========================================================
### 1) CATALOGUE PUBLIC
### =========================================================

### PRODUCTS - liste
GET {{baseUrl}}/api/products
Accept: {{json}}

### PRODUCT - détail 1
GET {{baseUrl}}/api/products/boucles-oreilles-naturelle-feuille
Accept: {{json}}

### PRODUCT - détail 2
GET {{baseUrl}}/api/products/dessous-de-verre-cest-la-vie
Accept: {{json}}

### PRODUCT - détail 3
GET {{baseUrl}}/api/products/marque-page-floralys-lavande
Accept: {{json}}

### CATEGORIES - liste
GET {{baseUrl}}/api/categories
Accept: {{json}}

### CATEGORY - détail bijoux
GET {{baseUrl}}/api/categories/bijoux
Accept: {{json}}

### CATEGORY - détail deco
GET {{baseUrl}}/api/categories/deco
Accept: {{json}}

### CATEGORY - détail lecture
GET {{baseUrl}}/api/categories/lecture
Accept: {{json}}

### CATEGORY PRODUCTS - bijoux
GET {{baseUrl}}/api/categories/bijoux/products
Accept: {{json}}

### CATEGORY PRODUCTS - deco
GET {{baseUrl}}/api/categories/deco/products
Accept: {{json}}

### CATEGORY PRODUCTS - lecture
GET {{baseUrl}}/api/categories/lecture/products
Accept: {{json}}

### =========================================================
### 2) LOGIN CLIENT
### =========================================================

### LOGIN CLIENT
# @name loginClient
POST {{baseUrl}}/api/login_check
Content-Type: {{json}}
Accept: {{json}}

{
  "email": "client3@krea.local",
  "password": "Client123!"
}

### =========================================================
### 3) PARCOURS COMMANDE + PAIEMENT
### =========================================================

### CLIENT - mes commandes avant création
GET {{baseUrl}}/api/orders/my
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### CLIENT - créer commande depuis produit 74
# @name createOrderFromProduct
POST {{baseUrl}}/api/orders/from-product/74
Accept: {{json}}
Content-Type: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

{}

### CLIENT - détail de la commande créée
GET {{baseUrl}}/api/orders/{{createOrderFromProduct.response.body.orderId}}
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### CLIENT - mes commandes après création
GET {{baseUrl}}/api/orders/my
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### CLIENT - créer session Stripe
# @name checkoutStripe
POST {{baseUrl}}/api/checkout/session/{{createOrderFromProduct.response.body.orderId}}
Accept: {{json}}
Content-Type: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

{}

### CLIENT - confirmation backend du paiement
GET {{baseUrl}}/api/checkout/confirm/{{createOrderFromProduct.response.body.orderId}}
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### CLIENT - reconsulter la commande après confirm
GET {{baseUrl}}/api/orders/{{createOrderFromProduct.response.body.orderId}}
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### =========================================================
### 4) PARCOURS ANNULATION
### =========================================================

### CLIENT - créer une deuxième commande pour test annulation
# @name createOrderToCancel
POST {{baseUrl}}/api/orders/from-product/74
Accept: {{json}}
Content-Type: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

{}

### CLIENT - détail avant annulation
GET {{baseUrl}}/api/orders/{{createOrderToCancel.response.body.orderId}}
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### CLIENT - annuler la commande créée
POST {{baseUrl}}/api/orders/{{createOrderToCancel.response.body.orderId}}/cancel
Accept: {{json}}
Content-Type: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

{}

### CLIENT - détail après annulation
GET {{baseUrl}}/api/orders/{{createOrderToCancel.response.body.orderId}}
Accept: {{json}}
Authorization: Bearer {{loginClient.response.body.token}}

### =========================================================
### 5) LOGIN ADMIN
### =========================================================

### LOGIN ADMIN
# @name loginAdmin
POST {{baseUrl}}/api/login_check
Content-Type: {{json}}
Accept: {{json}}

{
  "email": "admin@krea.local",
  "password": "Admin123!"
}

### ADMIN - ping privé
GET {{baseUrl}}/api/private/ping
Accept: {{json}}
Authorization: Bearer {{loginAdmin.response.body.token}}

### ADMIN - mes commandes
GET {{baseUrl}}/api/orders/my
Accept: {{json}}
Authorization: Bearer {{loginAdmin.response.body.token}}

### ADMIN - détail commande 1
GET {{baseUrl}}/api/orders/1
Accept: {{json}}
Authorization: Bearer {{loginAdmin.response.body.token}}

### =========================================================
### 6) WEBHOOK
### =========================================================

### WEBHOOK TEST MANUEL
### Ce test est surtout utile pour vérifier que la route existe.
### Si la signature Stripe est activement vérifiée, un échec est normal.
POST {{baseUrl}}/api/stripe/webhook
Content-Type: application/json

{
  "id": "evt_test_webhook",
  "type": "checkout.session.completed",
  "data": {
    "object": {
      "id": "cs_test_123456"
    }
  }
}

