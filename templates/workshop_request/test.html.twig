{% extends 'base.html.twig' %}

{% block title %}Test formulaire demande atelier{% endblock %}

{% block body %}
    <div class="container py-4 py-lg-5">
        {# ------------------------------------------------------------------ #}
        {# En-tête de page                                                    #}
        {# ------------------------------------------------------------------ #}
        <div class="row justify-content-center mb-4">
            <div class="col-12 col-xl-10">
                <div class="p-4 p-lg-5 bg-light border rounded-4 shadow-sm">
                    <span class="badge text-bg-dark mb-3">Test Symfony V1</span>
                    <h1 class="h2 mb-3">Formulaire de demande atelier / devis</h1>
                    <p class="text-muted mb-0">
                        Cette page sert à tester la structure V1 du formulaire Symfony :
                        affichage, validation, soumission et enregistrement en base.
                    </p>
                </div>
            </div>
        </div>

        {# ------------------------------------------------------------------ #}
        {# Messages flash                                                     #}
        {# ------------------------------------------------------------------ #}
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
                {% for message in app.flashes('danger') %}
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
                
            </div>
        </div>

        {# ------------------------------------------------------------------ #}
        {# Formulaire principal                                               #}
        {# ------------------------------------------------------------------ #}
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        {{ form_start(form, {
                            attr: {
                                'data-turbo': 'false'
                            }
                        }) }}

                        {# -------------------------------------------------------------- #}
                        {# Erreurs globales du formulaire principal                        #}
                        {# -------------------------------------------------------------- #}
                        {{ form_errors(form) }}

                        {# -------------------------------------------------------------- #}
                        {# Informations demandeur                                          #}
                        {# -------------------------------------------------------------- #}
                        <section class="mb-5">
                            <div class="mb-3">
                                <h2 class="h4 mb-1">Informations demandeur</h2>
                                <p class="text-muted mb-0">
                                    Qui fait la demande et comment recontacter la personne.
                                </p>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    {{ form_row(form.customerType) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.preferredContactMethod) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.fullName) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.email) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.phone) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.companyName) }}
                                </div>
                            </div>
                        </section>

                        <hr class="my-4">

                        {# -------------------------------------------------------------- #}
                        {# Nature de la demande                                            #}
                        {# -------------------------------------------------------------- #}
                        <section class="my-5">
                            <div class="mb-3">
                                <h2 class="h4 mb-1">Nature de la demande</h2>
                                <p class="text-muted mb-0">
                                    On précise ici le type de demande et le besoin principal.
                                </p>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    {{ form_row(form.requestType) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.requiresQuote) }}
                                </div>

                                <div class="col-12">
                                    {{ form_row(form.subject) }}
                                </div>

                                <div class="col-12">
                                    {{ form_row(form.message) }}
                                </div>
                            </div>
                        </section>

                        <hr class="my-4">

                        {# -------------------------------------------------------------- #}
                        {# Lignes de besoin produit                                        #}
                        {# -------------------------------------------------------------- #}
                        <section class="my-5">
                            <div class="mb-3">
                                <h2 class="h4 mb-1">Produits souhaités</h2>
                                <p class="text-muted mb-0">
                                    Ajoute ici une ou plusieurs idées produit. Pour les demandes de devis,
                                    précommandes, demandes pro ou événementielles, au moins une ligne est
                                    généralement nécessaire.
                                </p>
                            </div>

                            {# ---------------------------------------------------------- #}
                            {# Erreurs globales du bloc items                            #}
                            {# ---------------------------------------------------------- #}
                            {{ form_errors(form.items) }}

                            <div class="d-flex flex-column gap-4">
                                {% for itemForm in form.items %}
                                    <div class="border rounded-4 p-4 bg-light">
                                        <div class="mb-3">
                                            <h3 class="h5 mb-1">Besoin produit n°{{ loop.index }}</h3>
                                            <p class="text-muted small mb-0">
                                                Tu peux choisir un produit du catalogue, une catégorie,
                                                ou simplement décrire ton idée librement.
                                            </p>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                {{ form_row(itemForm.category) }}
                                            </div>

                                            <div class="col-md-6">
                                                {{ form_row(itemForm.product) }}
                                            </div>

                                            <div class="col-md-8">
                                                {{ form_row(itemForm.customLabel) }}
                                            </div>

                                            <div class="col-md-4">
                                                {{ form_row(itemForm.quantity) }}
                                            </div>

                                            <div class="col-12">
                                                {{ form_row(itemForm.personalizationText) }}
                                            </div>

                                            <div class="col-md-6">
                                                {{ form_row(itemForm.materialNotes) }}
                                            </div>

                                            <div class="col-md-6">
                                                {{ form_row(itemForm.formatNotes) }}
                                            </div>

                                            <div class="col-md-6">
                                                {{ form_row(itemForm.colorNotes) }}
                                            </div>

                                            <div class="col-md-6">
                                                {{ form_row(itemForm.dimensionsNotes) }}
                                            </div>

                                            <div class="col-12">
                                                {{ form_row(itemForm.lineMessage) }}
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="alert alert-warning mb-0">
                                        Aucune ligne produit n’est actuellement affichée.
                                        Ajoute une ligne côté contrôleur pour le test initial.
                                    </div>
                                {% endfor %}
                            </div>
                        </section>

                        <hr class="my-4">

                        {# -------------------------------------------------------------- #}
                        {# Contexte projet / événement                                     #}
                        {# -------------------------------------------------------------- #}
                        <section class="my-5">
                            <div class="mb-3">
                                <h2 class="h4 mb-1">Contexte du projet</h2>
                                <p class="text-muted mb-0">
                                    À compléter si la demande concerne une date, un événement
                                    ou une organisation particulière.
                                </p>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    {{ form_row(form.eventName) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.deliveryMethod) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.desiredDate) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.eventDate) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.budgetNotes) }}
                                </div>

                                <div class="col-md-6">
                                    {{ form_row(form.deadlineNotes) }}
                                </div>
                            </div>
                        </section>

                        <hr class="my-4">

                        {# -------------------------------------------------------------- #}
                        {# Consentement                                                    #}
                        {# -------------------------------------------------------------- #}
                        <section class="my-5">
                            <div class="mb-3">
                                <h2 class="h4 mb-1">Consentement</h2>
                                <p class="text-muted mb-0">
                                    Validation nécessaire pour pouvoir traiter la demande.
                                </p>
                            </div>

                            <div class="row g-3">
                                <div class="col-12">
                                    {{ form_row(form.consentRgpd) }}
                                </div>
                            </div>
                        </section>

                        {# -------------------------------------------------------------- #}
                        {# Actions                                                         #}
                        {# -------------------------------------------------------------- #}
                        <div class="d-flex flex-column flex-md-row gap-2 justify-content-between align-items-md-center pt-3 border-top">
                            <p class="text-muted small mb-0">
                                Test technique de la V1 WorkshopRequest.
                            </p>
                            {{ form_rest(form) }}
                            <button type="submit" class="btn btn-primary btn-lg px-4">
                                Enregistrer la demande de test
                            </button>
                        </div>

                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}