{% extends 'base.html.twig' %}

{% block title %}Accueil — Krea-Gravure{% endblock %}

{% block body %}
  <div class="p-4 p-md-5 mb-4 rounded-4 bg-white shadow-sm border">
    <div class="row align-items-center g-4">
      <div class="col-md-7">
        <h1 class="display-6 fw-bold mb-2">Krea-Gravure</h1>
        <p class="lead text-muted mb-3">
          Objets personnalisés en bois, gravure laser, cadeaux et déco.
          Du local, du propre, du sur-mesure.
        </p>

        <div class="d-flex flex-wrap gap-2">
          <a href="/admin" class="btn btn-dark">Accéder au Dashboard</a>
          {% if app.user %}
            <a href="{{ path('app_logout') }}" class="btn btn-outline-dark"
               onclick="event.preventDefault(); this.closest('div').querySelector('#logoutForm').submit();">
              Déconnexion
            </a>
            <form id="logoutForm" method="post" action="{{ path('app_logout') }}" class="d-none"></form>
          {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-outline-dark">Connexion</a>
            <a href="{{ path('app_register') }}" class="btn btn-warning">Créer un compte</a>
          {% endif %}
        </div>

        <div class="mt-3 small text-muted">
          {% if app.user %}
            Connecté : <strong>{{ app.user.userIdentifier }}</strong>
          {% else %}
            Astuce : crée un compte “user” pour tester l’access denied sur /admin 😉
          {% endif %}
        </div>
      </div>

      <div class="col-md-5">
        <div class="rounded-4 bg-light border p-4 h-100">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="badge text-bg-dark">Statut</span>
            <span class="badge {{ app.user ? 'text-bg-success' : 'text-bg-secondary' }}">
              {{ app.user ? 'Connecté' : 'Invité' }}
            </span>
          </div>

          <div class="small text-muted mb-2">Rôles</div>
          <div class="d-flex flex-wrap gap-2">
            {% if app.user %}
              {% for r in app.user.roles %}
                <span class="badge text-bg-light border">{{ r }}</span>
              {% endfor %}
            {% else %}
              <span class="badge text-bg-light border">Public</span>
            {% endif %}
          </div>

          <hr>

          <div class="small text-muted">Accès rapides</div>
          <div class="d-grid gap-2 mt-2">
            <a href="/admin" class="btn btn-outline-dark btn-sm">/admin (protégé)</a>
            <a href="{{ path('app_access_denied') }}" class="btn btn-outline-secondary btn-sm">/access-denied</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h2 class="h5 fw-bold mb-2">Produits</h2>
          <p class="text-muted mb-3">Porte-clés, dessous de verre, bijoux, déco…</p>
          <a href="#" class="btn btn-outline-dark btn-sm disabled">Bientôt</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h2 class="h5 fw-bold mb-2">Commandes</h2>
          <p class="text-muted mb-3">Gérer les commandes, clients, paiements.</p>
          <a href="/admin" class="btn btn-outline-dark btn-sm">Aller au dashboard</a>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h2 class="h5 fw-bold mb-2">Sécurité</h2>
          <p class="text-muted mb-3">Login/Register + /admin protégé + 403 custom.</p>
          <a href="{{ path('app_login') }}" class="btn btn-outline-dark btn-sm">Tester</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}