<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}Krea-Gravure{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {# ✅ Bootstrap CSS (CDN) #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
      {% block importmap %}{{ importmap('app') }}{% endblock %}

      {# ✅ Bootstrap JS (CDN) #}
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    {% endblock %}
  </head>

  <body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('front_home') ?? '#' }}">Krea-Gravure</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarKrea" aria-controls="navbarKrea" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarKrea">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
            {% if app.user %}
              <li class="nav-item">
                <span class="nav-link text-white-50 small">
                  {{ app.user.userIdentifier }}
                </span>
              </li>

              <li class="nav-item">
                <form method="post" action="{{ path('app_logout') }}" class="d-inline">
                  <button type="submit" class="btn btn-outline-light btn-sm">
                    Déconnexion
                  </button>
                </form>
              </li>
            {% else %}
              <li class="nav-item">
                <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">Connexion</a>
              </li>
              <li class="nav-item">
                <a class="btn btn-warning btn-sm" href="{{ path('app_register') }}">Inscription</a>
              </li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4">

      {# ✅ Flash messages Bootstrap #}
      {% for label, messages in app.flashes %}
        {% for message in messages %}
          {% set bs = (label == 'success') ? 'success'
            : (label == 'error' or label == 'danger') ? 'danger'
            : (label == 'warning') ? 'warning'
            : 'info'
          %}
          <div class="alert alert-{{ bs }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        {% endfor %}
      {% endfor %}
      <div class="container small text-muted py-2">
        env={{ app.environment }} | debug={{ app.debug ? '1' : '0' }}
      </div>
      {% block body %}{% endblock %}
    </main>

  </body>
</html>