{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
  <div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">

          <div class="d-flex align-items-start justify-content-between mb-3">
            <div>
              <h1 class="h4 mb-1">Créer un compte</h1>
              <p class="text-muted mb-0 small">Inscription rapide pour accéder à votre espace.</p>
            </div>
            <span class="badge {{ app.user ? 'text-bg-success' : 'text-bg-secondary' }}">
              {{ app.user ? 'Connecté' : 'Invité' }}
            </span>
          </div>

          {# ✅ Bloc debug (optionnel) : connecté + rôles #}
          {% if app.user %}
            <div class="alert alert-success py-2 small mb-3">
              <div><strong>{{ app.user.userIdentifier }}</strong></div>
              <div class="mt-1">
                {% for r in app.user.roles %}
                  <span class="badge text-bg-light border me-1">{{ r }}</span>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {# ✅ Erreurs globales du formulaire #}
          {% if form_errors(registrationForm) %}
            <div class="alert alert-danger">
              {{ form_errors(registrationForm) }}
            </div>
          {% endif %}

          {{ form_start(registrationForm) }}

            <div class="mb-3">
              {{ form_row(registrationForm.email, {
                label: 'Email',
                attr: { class: 'form-control' }
              }) }}
            </div>

            <div class="mb-3">
              {{ form_row(registrationForm.plainPassword, {
                label: 'Mot de passe',
                attr: { class: 'form-control' }
              }) }}
              <div class="form-text">
                Utilise un mot de passe solide (8+ caractères recommandé).
              </div>
            </div>

            <div class="form-check mb-3">
              {{ form_widget(registrationForm.agreeTerms, { attr: { class: 'form-check-input' } }) }}
              {{ form_label(registrationForm.agreeTerms, null, { label_attr: { class: 'form-check-label' } }) }}
              {{ form_errors(registrationForm.agreeTerms) }}
            </div>

            <button type="submit" class="btn btn-dark w-100">
              Créer mon compte
            </button>

            <div class="text-center mt-3">
              <span class="text-muted small">Déjà un compte ?</span>
              <a class="small fw-semibold" href="{{ path('app_login') }}">Se connecter</a>
            </div>

          {{ form_end(registrationForm) }}

        </div>
      </div>

      <div class="text-center mt-3 text-muted small">
        © {{ "now"|date("Y") }} Krea-Gravure
      </div>

    </div>
  </div>
{% endblock %}